---
import presentation from "@/data/presentation";
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<header
  class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/80 backdrop-blur-md dark:border-slate-800/70 dark:bg-slate-950/70"
>
  <div
    class="mx-auto flex h-14 max-w-page items-center justify-between gap-4 px-6 md:px-10"
  >
    <a
      href="/"
      class="group inline-flex items-baseline text-sm font-semibold tracking-tight text-slate-900 transition-colors dark:text-slate-50"
    >
      <span class="transition-colors group-hover:text-slate-500 dark:group-hover:text-slate-400">
        omar
      </span>
      <span class="text-slate-400 transition-colors group-hover:text-slate-900 dark:text-slate-600 dark:group-hover:text-slate-50">
        /
      </span>
      <span class="text-slate-500 transition-colors group-hover:text-slate-900 dark:text-slate-400 dark:group-hover:text-slate-50">
        adel
      </span>
    </a>

    <div class="ml-auto flex items-center gap-3">
      <nav aria-label="Primary">
        <ul class="flex items-center gap-0.5 text-xs">
          {
            presentation.navLinks.map((link, idx) => (
              <>
                <li>
                  <a
                    href={link.link}
                    target={link.link.startsWith("http") ? "_blank" : "_self"}
                    rel="noreferrer"
                    aria-label={link.label}
                    class="group inline-flex items-center gap-1 rounded-md px-1.5 py-1 text-slate-600 transition hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-50"
                  >
                    <Icon
                      name={link.icon}
                      class="h-3.5 w-3.5 text-slate-500 transition group-hover:text-slate-900 dark:text-slate-500 dark:group-hover:text-slate-50"
                    />
                    <span class="hidden md:inline">{link.label}</span>
                  </a>
                </li>
                {idx !== presentation.navLinks.length - 1 && (
                  <li
                    aria-hidden="true"
                    class="select-none text-slate-300 dark:text-slate-700"
                  >
                    /
                  </li>
                )}
              </>
            ))
          }
        </ul>
      </nav>

      <ThemeToggle />
    </div>
  </div>
</header>
