---
import Header from "../components/Header.astro";
import SEOTags from "@/components/seo/SEOTags.astro";
import type { HeadTags } from "@/utils/types/HeadTags";

import "@fontsource-variable/bricolage-grotesque";
import "@fontsource/dm-mono/400.css";
import "@fontsource/dm-mono/500.css";
import "@/styles/tailwind.css";
import "@/styles/post.css";

export type Props = HeadTags;

const headTags = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="h-full">
  <SEOTags {...headTags} />

  <script is:inline>
    (function () {
      try {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)"
        ).matches;
        const isDark = stored ? stored === "dark" : prefersDark;
        if (isDark) document.documentElement.classList.add("dark");
      } catch (_) {
        if (
          window.matchMedia &&
          window.matchMedia("(prefers-color-scheme: dark)").matches
        ) {
          document.documentElement.classList.add("dark");
        }
      }
    })();
  </script>

  <body
    class="min-h-full bg-white text-slate-700 antialiased transition-colors duration-150 dark:bg-slate-950 dark:text-slate-300"
  >
    <div class="flex min-h-screen flex-col">
      <Header />
      <main class="flex flex-1 flex-col">
        <slot />
      </main>
      <footer
        class="border-t border-slate-200 bg-white py-8 text-xs text-slate-500 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-500"
      >
        <div class="mx-auto flex max-w-page flex-col items-center justify-between gap-2 px-6 md:flex-row md:px-10">
          <span>© {new Date().getFullYear()} Omar Adel.</span>
          <span class="text-slate-400 dark:text-slate-600">
            Built in Alexandria, Egypt.
          </span>
        </div>
      </footer>
    </div>
    <style is:global>
      html {
        font-family: "Bricolage Grotesque Variable", "Bricolage Grotesque",
          ui-sans-serif, system-ui, sans-serif;
      }
      code,
      pre,
      kbd,
      samp {
        font-family: "DM Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      html.dark {
        color-scheme: dark;
      }
    </style>
  </body>
</html>
