---
import { Image } from "astro:assets";

import Layout from "@/layouts/Layout.astro";
import Icon from "@/components/Icon.astro";

import presentation from "@/data/presentation";
import services from "@/data/services";
import companies from "@/data/companies";
import portfolio from "@/data/portfolio";
import site from "@/data/site";

type Metric = {
  value: string;
  labelPrefix?: string;
  labelSuffix?: string;
  link?: {
    label: string;
    href: string;
    icon?: "turing";
    iconSrc?: string;
  };
  label?: string;
};

const metrics: Metric[] = [
  { value: "6+", label: "Fortune 500 companies supported" },
  {
    value: "$4M+",
    labelPrefix: "in contracts won with",
    link: {
      label: "Turing",
      href: "https://www.turing.com",
      icon: "turing",
    },
  },
  {
    value: "20k+",
    labelSuffix: "downloads",
    link: {
      label: "HuggingFace",
      href: "https://huggingface.co/omarxadel",
      iconSrc: "/companies/huggingface.svg",
    },
  },
  {
    value: "~$5k",
    labelPrefix: "in total revenue at",
    labelSuffix: ", my startup — contracts + products",
    link: { label: "Bolder", href: "https://bolder.fit" },
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="bg-white dark:bg-slate-950">
    <div
      class="mx-auto flex max-w-page flex-col items-center gap-12 px-6 pb-20 pt-12 text-center md:px-10 md:pb-28 md:pt-20"
    >
      <div class="relative">
        <div
          class="absolute inset-0 -z-10 rounded-full bg-slate-200/60 blur-2xl dark:bg-slate-800/60"
        >
        </div>
        <div
          class="overflow-hidden rounded-full border border-slate-200 bg-slate-100 ring-4 ring-white dark:border-slate-800 dark:bg-slate-900 dark:ring-slate-950"
        >
          <Image
            src={presentation.profile}
            alt="Omar Adel"
            width="208"
            height="208"
            class="h-44 w-44 grayscale md:h-52 md:w-52"
          />
        </div>

        <span
          class="absolute -right-6 top-6 inline-flex rotate-[14deg] items-center gap-1.5 rounded-full border border-slate-900/10 bg-slate-900 px-3.5 py-1.5 text-xs font-medium tracking-tight text-white shadow-lg shadow-slate-900/20 ring-1 ring-white/40 transition-transform duration-300 hover:rotate-[8deg] hover:scale-105 dark:border-white/10 dark:bg-white dark:text-slate-900 dark:shadow-black/40 dark:ring-slate-900/60 md:-right-8 md:top-8"
        >
          <span class="text-sm leading-none">{presentation.status.emoji}</span>
          <span>{presentation.status.label}</span>
        </span>
      </div>

      <div class="flex flex-col items-center gap-5">
        {
          presentation.roles?.length > 0 && (
            <p
              aria-label="Role"
              class="flex flex-wrap items-center justify-center gap-2 font-mono text-[11px] uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400"
            >
              {presentation.roles.map((role, i) => (
                <>
                  <span>{role}</span>
                  {i !== presentation.roles.length - 1 && (
                    <span
                      aria-hidden="true"
                      class="text-slate-300 dark:text-slate-700"
                    >
                      /
                    </span>
                  )}
                </>
              ))}
            </p>
          )
        }

        <h1
          class="max-w-3xl text-balance text-3xl font-semibold leading-tight tracking-tight text-slate-900 dark:text-slate-50 md:text-5xl md:leading-[1.05]"
        >
          {presentation.headline}
        </h1>

        {
          presentation.subhead && (
            <p class="max-w-xl text-balance text-base text-slate-600 dark:text-slate-400 md:text-lg">
              {presentation.subhead}
            </p>
          )
        }

        <div class="mt-2 flex flex-wrap items-center justify-center gap-3">
          <a
            href={presentation.cta.href}
            target="_blank"
            rel="noreferrer"
            class="group inline-flex items-center gap-2.5 rounded-full bg-slate-900 px-8 py-4 text-base font-medium text-white transition hover:bg-slate-700 dark:bg-slate-50 dark:text-slate-900 dark:hover:bg-slate-200"
          >
            {presentation.cta.label}
            <Icon
              name="arrow-up-right"
              class="h-5 w-5 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
            />
          </a>
        </div>
      </div>

      <!-- Metrics -->
      <dl
        class="mt-6 grid w-full max-w-3xl grid-cols-2 divide-slate-200 overflow-hidden rounded-2xl border border-slate-200 bg-white text-left dark:divide-slate-800 dark:border-slate-800 dark:bg-slate-950 md:grid-cols-4 md:divide-x"
      >
        {
          metrics.map((m, i) => (
            <div
              class:list={[
                "flex flex-col gap-1 px-5 py-5 md:px-6 md:py-6",
                i < 2 ? "border-b border-slate-200 dark:border-slate-800 md:border-b-0" : "",
                i % 2 === 1 ? "" : "border-r border-slate-200 dark:border-slate-800 md:border-r-0",
              ]}
            >
              <dt class="font-mono text-3xl font-medium tracking-tight text-slate-900 dark:text-slate-50 md:text-4xl">
                {m.value}
              </dt>
              <dd class="text-xs leading-snug text-slate-500 dark:text-slate-400">
                {m.label}
                {m.labelPrefix && <span>{m.labelPrefix} </span>}
                {m.link && (
                  <a
                    href={m.link.href}
                    target="_blank"
                    rel="noreferrer"
                    class="group inline-flex items-baseline gap-1 font-medium text-slate-900 underline decoration-slate-300 underline-offset-2 transition hover:decoration-slate-700 dark:text-slate-100 dark:decoration-slate-700 dark:hover:decoration-slate-400"
                  >
                    {m.link.iconSrc ? (
                      <img
                        src={m.link.iconSrc}
                        alt=""
                        aria-hidden="true"
                        loading="lazy"
                        class="h-4 w-auto self-center"
                      />
                    ) : m.link.icon ? (
                      <Icon
                        name={m.link.icon}
                        class="h-4 w-auto self-center text-slate-700 dark:text-slate-300"
                      />
                    ) : null}
                    {m.link.label}
                  </a>
                )}
                {m.labelSuffix && <span>{m.labelSuffix}</span>}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  <!-- Logo strip -->
  <section class="bg-slate-100 dark:bg-slate-900">
    <div class="mx-auto max-w-page px-6 py-10 md:px-10 md:py-14">
      <div
        class="grid grid-cols-3 items-center gap-x-6 gap-y-8 text-slate-500 dark:text-slate-500 md:grid-cols-6"
      >
        {
          companies.map((c) => {
            const Wrapper = c.href ? "a" : "span";
            const wrapperProps = c.href
              ? { href: c.href, target: "_blank", rel: "noreferrer" }
              : {};
            return (
              <div class="flex items-center justify-center">
                <Wrapper
                  {...wrapperProps}
                  aria-label={c.name}
                  class="inline-flex h-7 items-center justify-center opacity-70 transition hover:opacity-100"
                >
                  {c.logo ? (
                    <>
                      <img
                        src={c.logo}
                        alt={c.name}
                        loading="lazy"
                        class:list={[
                          "h-7 w-auto object-contain",
                          c.logoDark
                            ? "dark:hidden"
                            : (c.tone ?? "dark") === "dark"
                            ? "invert dark:invert-0"
                            : "dark:invert",
                        ]}
                      />
                      {c.logoDark && (
                        <img
                          src={c.logoDark}
                          alt={c.name}
                          loading="lazy"
                          class="hidden h-7 w-auto object-contain dark:block"
                        />
                      )}
                    </>
                  ) : (
                    <span class="text-sm font-medium tracking-tight">
                      {c.name}
                    </span>
                  )}
                </Wrapper>
              </div>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- Collaboration / Services -->
  <section id="services" class="bg-white dark:bg-slate-950">
    <div
      class="mx-auto flex max-w-page flex-col items-center gap-12 px-6 py-20 text-center md:px-10 md:py-28"
    >
      <div class="flex flex-col items-center gap-3">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-slate-200 px-3 py-1 text-xs uppercase tracking-[0.18em] text-slate-500 dark:border-slate-800 dark:text-slate-400"
        >
          How I work
        </span>
        <h2
          class="max-w-3xl text-balance text-2xl font-semibold leading-snug tracking-tight text-slate-900 dark:text-slate-50 md:text-3xl"
        >
          {site.collaborationStatement}
        </h2>
      </div>

      <div
        class="grid w-full grid-cols-1 gap-px overflow-hidden rounded-2xl border border-slate-200 bg-slate-200 text-left dark:border-slate-800 dark:bg-slate-800 sm:grid-cols-2"
      >
        {
          services.map((s) => (
            <article class="flex flex-col gap-3 bg-white p-6 dark:bg-slate-950">
              <div class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-slate-50 text-slate-700 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-200">
                <Icon name={s.icon} class="h-5 w-5" />
              </div>
              <h3 class="text-base font-semibold text-slate-900 dark:text-slate-50">
                {s.title}
              </h3>
              <p class="text-sm leading-6 text-slate-600 dark:text-slate-400">
                {s.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Investment / portfolio -->
  <section class="bg-slate-100 dark:bg-slate-900">
    <div class="mx-auto flex max-w-page flex-col gap-10 px-6 py-20 md:px-10 md:py-28">
      <div class="flex flex-col gap-2">
        <span class="text-xs uppercase tracking-[0.18em] text-slate-500">
          Investment portfolio
        </span>
        <h2
          class="text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-50 md:text-3xl"
        >
          What I'm building at {portfolio.parentName}.
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-5">
        <div class="flex flex-col gap-5 lg:col-span-2">
          <p class="text-base leading-7 text-slate-600 dark:text-slate-400">
            {portfolio.parentBlurb}
          </p>
          {
            portfolio.parentHref && (
              <a
                href={portfolio.parentHref}
                target="_blank"
                rel="noreferrer"
                class="group inline-flex w-fit items-center gap-1.5 text-sm font-medium text-slate-900 dark:text-slate-100"
              >
                Visit {portfolio.parentName}
                <Icon
                  name="arrow-right"
                  class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
                />
              </a>
            )
          }
          <div
            class="mt-2 flex items-baseline gap-3 rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-950"
          >
            <span
              class="font-mono text-3xl font-medium tracking-tight text-slate-900 dark:text-slate-50"
            >
              {portfolio.mrr}
            </span>
            <span class="text-xs uppercase tracking-[0.18em] text-slate-500">
              combined monthly recurring revenue
            </span>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-4 lg:col-span-3 md:grid-cols-3">
          {
            portfolio.products.map((p) => (
              <article class="flex flex-col gap-3 rounded-xl border border-slate-200 bg-white p-5 transition hover:border-slate-300 dark:border-slate-800 dark:bg-slate-950 dark:hover:border-slate-700">
                <div class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 bg-slate-50 text-xs font-semibold uppercase text-slate-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200">
                  {p.name.charAt(0)}
                </div>
                <h3 class="text-base font-semibold text-slate-900 dark:text-slate-50">
                  {p.href ? (
                    <a
                      href={p.href}
                      target="_blank"
                      rel="noreferrer"
                      class="hover:underline"
                    >
                      {p.name}
                    </a>
                  ) : (
                    p.name
                  )}
                </h3>
                <p class="text-sm leading-6 text-slate-600 dark:text-slate-400">
                  {p.description}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Book a meeting -->
  <section class="bg-white dark:bg-slate-950">
    <div
      class="mx-auto flex max-w-page flex-col items-center gap-6 px-6 py-24 text-center md:px-10 md:py-32"
    >
      <span
        class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs uppercase tracking-[0.18em] text-slate-500 dark:border-slate-800 dark:bg-slate-900 dark:text-slate-400"
      >
        Let's talk
      </span>
      <h2
        class="max-w-2xl text-balance text-3xl font-semibold tracking-tight text-slate-900 dark:text-slate-50 md:text-5xl"
      >
        Book a meeting with me.
      </h2>
      <p class="max-w-xl text-base text-slate-600 dark:text-slate-400">
        Fastest way to see if there's a fit — pick a slot, share a one-liner about
        the problem, and we'll go from there.
      </p>
      <a
        href={site.calLink}
        target="_blank"
        rel="noreferrer"
        class="group mt-2 inline-flex items-center gap-2 rounded-full bg-slate-900 px-8 py-4 text-base font-medium text-white transition hover:bg-slate-700 dark:bg-slate-50 dark:text-slate-900 dark:hover:bg-slate-200"
      >
        <Icon name="calendar" class="h-4 w-4" />
        Book on Cal.com
        <Icon
          name="arrow-up-right"
          class="h-5 w-5 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
        />
      </a>
    </div>
  </section>
</Layout>
